local function createHDInput(fullName, pos, size)
	local bg = Instance.new("Frame")
	bg.Size = size
	bg.Position = pos
	bg.BackgroundColor3 = Color3.fromRGB(4, 10, 4)
	bg.BorderSizePixel = 0
	bg.Parent = contentCanvas
	table.insert(backgroundTracker, bg)
	
	local stroke = Instance.new("UIStroke", bg)
	stroke.Color = ACCENT_THEME
	table.insert(strokeTracker, stroke)

	local pfx = Instance.new("TextLabel")
	pfx.Size = UDim2.new(1, -10, 0, 12)
	pfx.Position = UDim2.new(0, 8, 0, -12)
	pfx.BackgroundTransparency = 1
	pfx.Text = string.lower(fullName)
	pfx.TextColor3 = CURRENT_THEME
	pfx.TextSize = 9
	pfx.Font = Enum.Font.Code
	pfx.TextXAlignment = Enum.TextXAlignment.Left
	pfx.Parent = bg
	table.insert(textTracker, pfx)

	local tb = Instance.new("TextBox")
	tb.Size = UDim2.new(1, -20, 1, 0)
	tb.Position = UDim2.new(0, 12, 0, 0)
	tb.BackgroundTransparency = 1
	tb.TextColor3 = CURRENT_THEME
	tb.PlaceholderText = "SET_" .. fullName .. "..."
	tb.PlaceholderColor3 = ACCENT_THEME
	tb.Text = ""
	tb.Font = Enum.Font.Code
	tb.TextSize = 11
	tb.TextXAlignment = Enum.TextXAlignment.Left
	tb.ClearTextOnFocus = false
	tb.Parent = bg
	table.insert(inputTextBoxes, tb)
	
	tb.Focused:Connect(function() 
		TweenService:Create(stroke, TweenInfo.new(0.15), {Color = CURRENT_THEME, Thickness = 1.5}):Play()
	end)
	tb.FocusLost:Connect(function() 
		TweenService:Create(stroke, TweenInfo.new(0.2), {Color = ACCENT_THEME, Thickness = 1}):Play()
	end)
	
	return tb
end

local function createHDButton(command, pos, size)
	local btn = Instance.new("TextButton")
	btn.Size = size
	btn.Position = pos
	btn.BackgroundColor3 = Color3.fromRGB(6, 14, 6)
	btn.TextColor3 = CURRENT_THEME
	btn.Text = ">> EXECUTE_" .. command
	btn.Font = Enum.Font.Code
	btn.TextSize = 11
	btn.Parent = contentCanvas
	table.insert(backgroundTracker, btn)
	table.insert(functionalButtons, btn)
	
	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = ACCENT_THEME
	table.insert(strokeTracker, stroke)
	
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = ACCENT_THEME, TextColor3 = CURRENT_THEME}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.1), {Color = CURRENT_THEME}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(6, 14, 6), TextColor3 = CURRENT_THEME}):Play()
		TweenService:Create(stroke, TweenInfo.new(0.15), {Color = ACCENT_THEME}):Play()
	end)
	
	return btn
end

