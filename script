		mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		uiStroke.Color = Color3.fromRGB(50, 0, 0)
		task.wait(0.08)
	end
	
	-- Captura de métricas geométricas del cuadro para el centro de la explosión
	local startAbsPos = mainFrame.AbsolutePosition
	local startAbsSize = mainFrame.AbsoluteSize
	local centerX = startAbsPos.X + (startAbsSize.X / 2)
	local centerY = startAbsPos.Y + (startAbsSize.Y / 2)
	
	mainFrame.Visible = false
	
	-- Contenedor temporal de partículas volátiles en pantalla
	local particleContainer = Instance.new("ScreenGui")
	particleContainer.Name = "AshesMatrix"
	particleContainer.Parent = playerGui
	
	local pixelGlyphs = {"█", "▓", "▒", "░", "■", "▪"}
	local particleTable = {}
	local rng = Random.new()
	
	-- Generar oleada masiva de fragmentos vectoriales pixelados
	for i = 1, 120 do
		local particle = Instance.new("TextLabel")
		particle.BackgroundTransparency = 1
		particle.Font = Enum.Font.Code
		particle.TextSize = rng:NextInteger(10, 24)
		particle.Text = pixelGlyphs[rng:NextInteger(1, #pixelGlyphs)]
		particle.TextColor3 = CURRENT_THEME:Lerp(Color3.fromRGB(255, 255, 255), rng:NextNumber(0, 0.4))
		
		-- Posicionamiento inicial en el baricentro de la ventana borrada
		particle.Position = UDim2.new(0, centerX + rng:NextInteger(-20, 20), 0, centerY + rng:NextInteger(-20, 20))
		particle.Parent = particleContainer
		
		-- Ecuación física de proyección radial (Ángulo + Fuerza de Empuje)
		local angle = rng:NextNumber(0, math.pi * 2)
		local speed = rng:NextNumber(150, 650)
		local velocityX = math.cos(angle) * speed
		local velocityY = math.sin(angle) * speed
		
		table.insert(particleTable, {
			Instance = particle,
			VelX = velocityX,
			VelY = velocityY,
			Alpha = 1
		})
	end
	
	-- Bucle de renderizado físico de la explosión (Simulación cinemática independiente)
	local duration = 1.2
	local elapsed = 0
	while elapsed < duration do
		local dt = task.wait()
		elapsed = elapsed + dt
		local progress = elapsed / duration
		
		for _, data in ipairs(particleTable) do
			local p = data.Instance
			-- Actualizar posición mediante diferencial de desplazamiento lineal
			local currentPos = p.Position
			p.Position = UDim2.new(
				0, currentPos.X.Offset + (data.VelX * dt), 
				0, currentPos.Y.Offset + (data.VelY * dt) + (180 * dt) -- Añade gravedad artificial leve descendente
			)
			-- Desvanecimiento alfa de los bloques de datos corruptos
			p.TextTransparency = progress
		end
	end
	
	-- Purga total: Borrado absoluto del ecosistema GUI de memoria del cliente
	particleContainer:Destroy()
	screenGui:Destroy()
	script:Destroy()
end)

