local resizing = false
local resizeStartPos
local frameStartSize

resizeHandle.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		resizing = true
		resizeStartPos = input.Position
		frameStartSize = mainFrame.Size
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then resizing = false end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - resizeStartPos
		local targetWidth = math.max(480, frameStartSize.X.Offset + delta.X)
		local targetHeight = math.max(220, frameStartSize.Y.Offset + delta.Y)
		mainFrame.Size = UDim2.new(0, targetWidth, 0, targetHeight)
	end
end)

